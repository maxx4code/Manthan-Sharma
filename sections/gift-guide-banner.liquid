
<section
  class="ggb"
  id="ggb-{{ section.id }}"
  style="
    --ggb-mb-desktop: {{ section.settings.margin_bottom_desktop }}px;
    --ggb-mb-mobile: {{ section.settings.margin_bottom_mobile }}px;
  "
>
  <header class="ggb__top page-width" role="banner">
    <button
      class="ggb__burger"
      type="button"
      aria-controls="ggb-panel-{{ section.id }}"
    >
      <span class="ggb__icon" aria-hidden="true">
        <svg
          class="ggb__iconMenu"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="12"
          viewBox="0 0 20 12"
          fill="none"
        >
          <path d="M1 6H19" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M1 1H19" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M1 11H19" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <svg
          class="ggb__iconClose"
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 15 15"
          fill="none"
        >
          <path d="M1 13.9994L13.7279 1.27147" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M1 1L13.7279 13.7279" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </button>

    <div class="ggb__brand">
      <span class="ggb__brandText">{{ section.settings.brand_text }}</span>
    </div>

    <p class="ggb__helper">
      {{ section.settings.helper_text }}
    </p>

    {%- if section.settings.top_cta_link != blank -%}
      <a class="ggb__btn ggb__btn--yellow ggb__btn--top" href="{{ section.settings.top_cta_link }}">
        <span class="ggb__btnLabel">{{ section.settings.top_cta_label }}</span>
        <span class="ggb__arrow" aria-hidden="true"></span>
      </a>
    {%- endif -%}
  </header>

  <div
    class="ggb__panel"
    id="ggb-panel-{{ section.id }}"
  >
    <p class="ggb__panelText">{{ section.settings.helper_text }}</p>

    {%- if section.settings.top_cta_link != blank -%}
      <a class="ggb__btn ggb__btn--yellow ggb__btn--panel" href="{{ section.settings.top_cta_link }}">
        <span class="ggb__btnLabel">{{ section.settings.top_cta_label }}</span>
        <span class="ggb__arrow" aria-hidden="true"></span>
      </a>
    {%- endif -%}
  </div>

  <div class="ggb__hero" role="region">
    <picture class="ggb__bg" aria-hidden="true">
      {%- if section.settings.mobile_image != blank -%}
        <source
          media="(max-width: 749px)"
          srcset="{{ section.settings.mobile_image | image_url: width: 750 }} 750w, {{ section.settings.mobile_image | image_url: width: 1100 }} 1100w"
          sizes="100vw"
        >
      {%- endif -%}

      {%- if section.settings.desktop_image != blank -%}
        <img
          class="ggb__img"
          src="{{ section.settings.desktop_image | image_url: width: 1800 }}"
          srcset="{{ section.settings.desktop_image | image_url: width: 1200 }} 1200w, {{ section.settings.desktop_image | image_url: width: 1800 }} 1800w, {{ section.settings.desktop_image | image_url: width: 2400 }} 2400w"
          sizes="100vw"
          alt=""
          loading="lazy"
          width="{{ section.settings.desktop_image.width }}"
          height="{{ section.settings.desktop_image.height }}"
        >
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'ggb__img ggb__placeholder' }}
      {%- endif -%}
    </picture>

    <div class="ggb__copy">
      <h2 class="ggb__title">{{ section.settings.heading }}</h2>
      <div class="ggb__desc rte">{{ section.settings.description }}</div>

      {%- if section.settings.primary_cta_link != blank -%}
        <a class="ggb__btn ggb__btn--black" href="{{ section.settings.primary_cta_link }}">
          <span class="ggb__btnLabel">{{ section.settings.primary_cta_label }}</span>
          <span class="ggb__arrow" aria-hidden="true"></span>
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.bottom_strip_text != blank -%}
    <div class="ggb__strip page-width" role="note">
      <span class="ggb__stripText">{{ section.settings.bottom_strip_text }}</span>
    </div>
  {%- endif -%}
</section>

<script></script>

{% schema %}
{
  "name": "Gift Guide Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "helper_text",
      "label": "Helper Text",
      "default": "Find the ideal gift for your loved ones,"
    },
    {
      "type": "text",
      "id": "top_cta_lable",
      "label": "Top CTA label",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "top_cta_link",
      "label": "TOP CTA link"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary CTA label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "bottom_strip_text",
      "label": "Bottom strip text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "margin_bottom_desktop",
      "label": "Margin bottom (desktop)px",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Margin bottom (mobile)px",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Gift Guide Banner"
    }
  ]
}
{% endschema %}
