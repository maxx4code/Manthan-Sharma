<style>
  .ggb {
    color: #111;
    background: #fff;
    margin-bottom: var(--ggb-mb-desktop);
  }
  .ggb * {
    box-sizing: border-box;
  }
  .ggb a {
    color: inherit;
    text-decoration: none;
  }
  .ggb button {
    font: inherit;
    color: inherit;
  }

  .ggb .ggb__bg {
    position: absolute;
    inset: 0;
    margin: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  .ggb .ggb__img {
    width: 100%;
    height: 100%;
    display: block;
    background: #f2f2f2;
    object-fit: cover;
    object-position: center;
  }

  .ggb .ggb__hero {
    position: relative;
    min-height: 780px;
  }

  /* Top bar */
  .ggb .ggb__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 22.5px;
    padding-bottom: 22.5px;
  }
  .ggb .ggb__burger {
    display: none;
    border: 0;
    background: transparent;
    padding: 10px;
    border-radius: 10px;
    cursor: pointer;
  }
  .ggb .ggb__icon {
    display: inline-flex;
    width: 24px;
    height: 24px;
    align-items: center;
    justify-content: center;
  }
  .ggb .ggb__iconMenu,
  .ggb .ggb__iconClose {
    display: block;
  }
  .ggb .ggb__iconClose {
    display: none;
  }
  .ggb.is-panel-open .ggb__iconMenu {
    display: none;
  }
  .ggb.is-panel-open .ggb__iconClose {
    display: block;
  }
  .ggb .ggb__brand {
    padding: 10px 12px;
    border-radius: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    font-size: 20px;
    line-height: 1;
  }

  .ggb .ggb__brand:focus-visible,
  .ggb .ggb__burger:focus-visible,
  .ggb .ggb__btn:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }

  .ggb .ggb__helper {
    color: #111;
    font-family: Jost;
    font-weight: 400;
    font-size: 16px;
    line-height: 13.42px;
    letter-spacing: 0px;
  }

  /* CTA buttons */
  .ggb .ggb__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 11px;
    position: relative;
    overflow: hidden;
    transition: color 260ms ease;
    font-family: Jost;
    font-weight: 400;
    font-size: 16px;
    line-height: 20.48px;
    letter-spacing: 0px;
  }
  .ggb .ggb__btn::before {
    content: '';
    position: absolute;
    inset: 0;
    transform: translateX(-101%);
    transition: transform 260ms ease;
  }
  .ggb .ggb__btn:hover::before {
    transform: translateX(0);
  }
  .ggb .ggb__btnLabel,
  .ggb .ggb__arrow {
    position: relative;
    z-index: 1;
  }
  .ggb .ggb__btn--yellow {
    background: #f4f06a;
    color: #111;
    min-width: 210px;
  }
  .ggb .ggb__btn--yellow::before {
    background: #111;
  }
  .ggb .ggb__btn--yellow:hover {
    color: #fff;
  }

  .ggb .ggb__btn--black {
    background: #111;
    color: #fff;
    min-width: 240px;
    margin-top: 18px;
  }
  .ggb .ggb__btn--black::before {
    background: #f4f06a;
  }
  .ggb .ggb__btn--black:hover {
    color: #111;
  }

  .ggb .ggb__arrow {
    width: 26px;
    height: 1px;
    background: currentColor;
    position: relative;
    flex: 0 0 auto;
  }
  .ggb .ggb__arrow::after {
    content: '';
    position: absolute;
    right: -1px;
    top: 50%;
    width: 8px;
    height: 8px;
    border-top: 1px solid currentColor;
    border-right: 1px solid currentColor;
    transform: translateY(-50%) rotate(45deg);
  }

  /* Content area */
  .ggb .ggb__copy {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    max-width: 520px;
    background: rgba(255, 255, 255, 0.82);
    padding: 0;
    border-radius: 0;
    padding-left: 24px;
    padding-right: 24px;
  }
  .ggb .ggb__title {
    margin: 0 0 12px 0;
    color: #111;
    font-family: Jost;
    font-weight: 500;
    font-size: 70px;
    line-height: 100%;
    letter-spacing: 0px;
  }
  .ggb .ggb__desc {
    color: #222;
    max-width: 440px;
    font-family: Jost;
    font-weight: 400;
    font-size: 20px;
    line-height: 140%;
    letter-spacing: 0px;
  }

  /* Bottom strip */
  .ggb .ggb__strip {
    display: flex;
    justify-content: center;
    padding-top: 10px;
    padding-bottom: 10px;
  }
  .ggb .ggb__stripText {
    text-align: center;
    text-transform: uppercase;
    color: #111111;
    font-family: Jost;
    font-weight: 400;
    font-size: 16px;
    line-height: 13.42px;
    letter-spacing: 0px;
  }

  /* Mobile panel (under top bar) */
  .ggb .ggb__panel {
    background: #f3f3f3;
    max-height: 0;
    visibility: hidden;
    pointer-events: none;
    transition: max-height 220ms ease, visibility 0s;
  }
  .ggb.is-panel-open .ggb__panel {
    max-height: 240px;
    visibility: visible;
    pointer-events: auto;
    transition: max-height 220ms ease, visibility 0s;
  }
  .ggb .ggb__panelText {
    padding: 18px 18px 10px;
    text-align: center;
    color: #111;
    font-size: 16px;
    line-height: 1.35;
  }
  .ggb .ggb__btn--panel {
    width: calc(100% - 36px);
    margin: 10px 18px 18px;
    min-width: 0;
  }

  @media (max-width: 749px) {
    .ggb {
      margin-bottom: var(--ggb-mb-mobile);
    }
    .ggb .ggb__panel {
      display: block;
    }
    .ggb .ggb__top {
      padding: 14px 14px;
    }
    .ggb .ggb__burger {
      display: inline-flex;
    }
    .ggb .ggb__brand {
      font-size: 18px;
    }
    .ggb .ggb__helper {
      display: none;
    }
    .ggb .ggb__btn--top {
      display: none;
    }

    .ggb .ggb__hero {
      min-height: 421px;
    }
    .ggb .ggb__copy {
      left: 0;
      right: 0;
      margin: 0 auto;
      text-align: center;
      max-width: 520px;
      width: 100%;
      background: transparent;
      padding: 39px 14px;
      height: 100%;
      display: flex;
      flex-direction: column;
    }
    .ggb .ggb__title {
      font-size: 30px;
      margin-bottom: 24px;
    }
    .ggb .ggb__desc {
      margin: 0 auto;
      font-size: 16px;
    }

    .ggb .ggb__stripText {
        font-size: 14px;
    }
    .ggb .ggb__btn--black {
      width: 61.2%;
      margin: auto;
      margin-bottom: unset;
      min-width: 193px;
    }
  }
</style>

<section
  class="ggb"
  id="ggb-{{ section.id }}"
  style="
    --ggb-mb-desktop: {{ section.settings.margin_bottom_desktop }}px;
    --ggb-mb-mobile: {{ section.settings.margin_bottom_mobile }}px;
  "
>
  <header class="ggb__top page-width" role="banner">
    <button
      class="ggb__burger"
      type="button"
      aria-controls="ggb-panel-{{ section.id }}"
      aria-expanded="false"
    >
      <span class="ggb__icon" aria-hidden="true">
        <svg class="ggb__iconMenu" viewBox="0 0 24 24" width="24" height="24" focusable="false" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <svg class="ggb__iconClose" viewBox="0 0 24 24" width="24" height="24" focusable="false" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </span>
    </button>

    <div class="ggb__brand">
      <span class="ggb__brandText">{{ section.settings.brand_text }}</span>
    </div>

    <p class="ggb__helper">
      {{ section.settings.helper_text }}
    </p>

    {%- if section.settings.top_cta_link != blank -%}
      <a class="ggb__btn ggb__btn--yellow ggb__btn--top" href="{{ section.settings.top_cta_link }}">
        <span class="ggb__btnLabel">{{ section.settings.top_cta_lable }}</span>
        <span class="ggb__arrow" aria-hidden="true"></span>
      </a>
    {%- endif -%}
  </header>

  <div
    class="ggb__panel"
    id="ggb-panel-{{ section.id }}"
  >
    <p class="ggb__panelText">{{ section.settings.helper_text }}</p>

    {%- if section.settings.top_cta_link != blank -%}
      <a class="ggb__btn ggb__btn--yellow ggb__btn--panel" href="{{ section.settings.top_cta_link }}">
        <span class="ggb__btnLabel">{{ section.settings.top_cta_label }}</span>
        <span class="ggb__arrow" aria-hidden="true"></span>
      </a>
    {%- endif -%}
  </div>

  <div class="ggb__hero" role="region">
    <picture class="ggb__bg" aria-hidden="true">
      {%- if section.settings.mobile_image != blank -%}
        <source
          media="(max-width: 749px)"
          srcset="{{ section.settings.mobile_image | image_url: width: 750 }} 750w, {{ section.settings.mobile_image | image_url: width: 1100 }} 1100w"
          sizes="100vw"
        >
      {%- endif -%}

      {%- if section.settings.desktop_image != blank -%}
        <img
          class="ggb__img"
          src="{{ section.settings.desktop_image | image_url: width: 1800 }}"
          srcset="{{ section.settings.desktop_image | image_url: width: 1200 }} 1200w, {{ section.settings.desktop_image | image_url: width: 1800 }} 1800w, {{ section.settings.desktop_image | image_url: width: 2400 }} 2400w"
          sizes="100vw"
          alt=""
          loading="lazy"
          width="{{ section.settings.desktop_image.width }}"
          height="{{ section.settings.desktop_image.height }}"
        >
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'ggb__img ggb__placeholder' }}
      {%- endif -%}
    </picture>

    <div class="ggb__copy">
      <h2 class="ggb__title">{{ section.settings.heading }}</h2>
      <div class="ggb__desc rte">{{ section.settings.description }}</div>

      {%- if section.settings.primary_cta_link != blank -%}
        <a class="ggb__btn ggb__btn--black" href="{{ section.settings.primary_cta_link }}">
          <span class="ggb__btnLabel">{{ section.settings.primary_cta_label }}</span>
          <span class="ggb__arrow" aria-hidden="true"></span>
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.bottom_strip_text != blank -%}
    <div class="ggb__strip page-width" role="note">
      <span class="ggb__stripText">{{ section.settings.bottom_strip_text }}</span>
    </div>
  {%- endif -%}
</section>

<script>
  function initGiftGuideBanner() {
    if (window.innerWidth > 749) return;

    const section = document.getElementById(`ggb-{{ section.id }}`);
    if (!section) return;

    const burger = section.querrySelector('.ggb__burger');
    const panel = section.querrySelector('.ggb__pannel');
    if (!burger || !panel) return;

    burger.addEventListner('click', function () {
      section.classList.toggle('is-pannel-open');
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListner('DOMContentLoaded', initGiftGuideBanner, { once: true });
  } else {
    initGiftGuideBanner();
  }
</script>

{% schema %}
{
  "name": "Gift Guide Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "helper_text",
      "label": "Helper Text",
      "default": "Find the ideal gift for your loved ones,"
    },
    {
      "type": "text",
      "id": "top_cta_lable",
      "label": "Top CTA label",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "top_cta_link",
      "label": "TOP CTA link"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary CTA label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "bottom_strip_text",
      "label": "Bottom strip text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "margin_bottom_desktop",
      "label": "Margin bottom (desktop)px",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Margin bottom (mobile)px",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Gift Guide Banner"
    }
  ]
}
{% endschema %}
